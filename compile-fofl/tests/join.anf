fun add_one(x : I32) : I32 := #i32-add(x, 1);

fun test(x : I32, y : I32) : I32 :=
  let cond := #i32-eq(x, 0);
  join j (p : I32) := #i32-add(p, 1);
  if cond then jump j y else jump j x;

fun test-tailcall(x : I32, y : I32) : I32 :=
  let cond := #i32-eq(x, 0);
  join j (p : I32) := add_one(p);
  if cond then jump j x else jump j y;
