fun test(b : Bool) : I32 :=
  let x : I32 := 42;
  join if_end (result : I32) := let y : I32 := result;
                                #i32-add(y, x);
  if b then
    let result_2 := #i32-add(x, 1);
    jump if_end result_2
  else
    let result_1 := #i32-sub(x, 1);
    jump if_end result_1;

fun test-branches(b : Bool) : I32 :=
  join if_end (result : I32) := result;
  if b then
    let x_1 : I32 := 42;
    let result_2 := #i32-add(x_1, 1);
    jump if_end result_2
  else
    let x : I32 := 3;
    let result_1 := #i32-sub(x, 1);
    jump if_end result_1;

fun test-shadow(x : I32) : I32 :=
  let x_1 : I32 := #i32-add(x, 1);
  let x_2 : I32 := #i32-mul(x_1, 3);
  x_2;
