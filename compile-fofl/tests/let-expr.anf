fun test(b : Bool) : I32 :=
  let x : I32 := 42;
  join branch (result : I32) := let y : I32 := result;
                                #i32-add(y, x);
  if b then
    let result_2 := #i32-add(x, 1);
    jump branch result_2
  else
    let result_1 := #i32-sub(x, 1);
    jump branch result_1;

fun text-shadow(x : I32) : I32 :=
  let x_1 : I32 := #i32-add(x, 1);
  let x_2 : I32 := #i32-mul(x_1, 3);
  x_2;
