fun is-even(n : I32) : Bool :=
  let cond := #i32-eq(n, 0);
  join j (p : Bool) := p;
  if cond then
    jump j true
  else
    let x := #i32-sub(n, 1);
    let r := is-odd(x);
    jump j r;

fun is-odd(n : I32) : Bool :=
  let cond := #i32-eq(n, 0);
  join j (p : Bool) := p;
  if cond then
    jump j false
  else
    let x := #i32-sub(n, 1);
    let r := is-even(x);
    jump j r;
