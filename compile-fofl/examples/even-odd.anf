fun is-even(n0 : I32) : Bool :=
  let cond2 := #i32-eq(n0, 0);
  join j0 (p1 : Bool) := p1;
  if cond2 then
    jump j0 true
  else
    let arg3 := #i32-sub(n0, 1);
    let result4 := is-odd(arg3);
    jump j0 result4;

fun is-odd(n5 : I32) : Bool :=
  let cond7 := #i32-eq(n5, 0);
  join j1 (p6 : Bool) := p6;
  if cond7 then
    jump j1 false
  else
    let arg8 := #i32-sub(n5, 1);
    let result9 := is-even(arg8);
    jump j1 result9;
