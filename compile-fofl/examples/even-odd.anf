fun is-even(n : I32) : Bool :=
  let cond := #i32-eq(n, 0);
  join branch (result : Bool) := result;
  if cond then
    jump branch true
  else
    let arg := #i32-sub(n, 1);
    let result_1 := is-odd(arg);
    jump branch result_1;

fun is-odd(n : I32) : Bool :=
  let cond := #i32-eq(n, 0);
  join branch (result : Bool) := result;
  if cond then
    jump branch false
  else
    let arg := #i32-sub(n, 1);
    let result_1 := is-even(arg);
    jump branch result_1;
