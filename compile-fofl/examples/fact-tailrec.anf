fun fact(n : I32) : I32 := fact-acc(n, 1);

fun fact-acc(n : I32, acc : I32) : I32 :=
  let cond := #i32-eq(n, 0);
  join if_end (result : I32) := result;
  if cond then
    jump if_end acc
  else
    let arg := #i32-sub(n, 1);
    let arg_1 := #i32-mul(n, acc);
    let result_1 := fact-acc(arg, arg_1);
    jump if_end result_1;

val test-fact : I32 := fact(5);
