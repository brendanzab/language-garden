fun fact(n : I32) : I32 :=
  let cond : Bool := #i32-eq(n, 0);
  join if_end (result : I32) := result;
  if cond then
    jump if_end 1
  else
    let arg : I32 := #i32-sub(n, 1);
    let arg_1 : I32 := fact(arg);
    let result_1 : I32 := #i32-mul(n, arg_1);
    jump if_end result_1;

val test-fact : I32 := fact(5);
