fun fun-app(f : fun (I32) -> Bool, x : I32) : Bool := f(x);

fun id-i32-bool(f : fun (I32) -> Bool) : fun (I32) -> Bool := f;

fun ignore-param(_ : fun (I32, Bool) -> I32) : I32 := 43;

fun is-one(x : I32) : Bool := #i32-eq(x, 1);

fun is-zero(x : I32) : Bool := #i32-eq(x, 0);

fun local-binding(f : fun (I32) -> I32, x : I32) : I32 :=
  let g : fun (I32) -> I32 := f;
  g(x);

val test-hof-1 : Bool := fun-app(is-zero, 3);

val test-hof-2 : Bool := fun-app(is-zero, 45);

val test-hof-3 : Bool := fun-app(is-one, 1);
