(executable
 (name dune_inc))

(subdir run
 (dynamic_include ../generate/dune.inc))

(subdir generate
 (rule
  (deps (glob_files ../*.txt))
  (action
   (with-stdout-to dune.inc
    (run ../dune_inc.exe)))))

(cram
 (package elab-record-patching)
 (deps %{bin:record-patching})
 (setup_scripts cram_setup.sh))

(rule
 (write-file cram_setup.sh
  "alias executable=%{bin:record-patching}"))
